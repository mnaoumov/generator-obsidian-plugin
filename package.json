{
  "name": "generator-obsidian-plugin",
  "version": "11.10.0",
  "description": "Obsidian Plugin Bootstrap",
  "keywords": [
    "obsidian",
    "plugin",
    "yeoman-generator"
  ],
  "homepage": "https://github.com/mnaoumov/generator-obsidian-plugin/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mnaoumov/generator-obsidian-plugin.git"
  },
  "license": "MIT",
  "author": {
    "name": "Michael Naumov",
    "email": "mnaoumov@gmail.com",
    "url": "https://github.com/mnaoumov/"
  },
  "type": "module",
  "main": "generators/index.js",
  "files": [
    "generators/",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "npm-shrinkwrap.json",
    "package.json"
  ],
  "scripts": {
    "build": "obsidian-dev-utils build",
    "build:compile": "obsidian-dev-utils build:compile",
    "commit": "cz",
    "format": "obsidian-dev-utils format",
    "format:check": "obsidian-dev-utils format:check",
    "lint": "obsidian-dev-utils lint",
    "lint:fix": "obsidian-dev-utils lint:fix",
    "prepare": "husky",
    "spellcheck": "obsidian-dev-utils spellcheck",
    "version": "obsidian-dev-utils version"
  },
  "dependencies": {
    "chalk": "latest",
    "semver": "latest",
    "yeoman-generator": "latest",
    "yosay": "latest"
  },
  "devDependencies": {
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@commitlint/types": "latest",
    "@tsconfig/strictest": "latest",
    "@types/debug": "latest",
    "@types/json-schema": "latest",
    "@types/semver": "latest",
    "@types/yosay": "latest",
    "@yeoman/adapter": "latest",
    "commitizen": "latest",
    "cz-conventional-changelog": "latest",
    "esbuild": "latest",
    "husky": "latest",
    "jiti": "latest",
    "npm-run-all": "latest",
    "obsidian-dev-utils": "latest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "@antfu/utils": "9.2.0",
    "dompurify": "3.0.1",
    "eslint-plugin-import": "npm:eslint-plugin-import-x@latest",
    "type-fest": "latest",
    "whatwg-url": "latest"
  }
}
